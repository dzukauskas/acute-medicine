direction: down

vars: {
  d2-config: {
    theme-id: 300
    layout-engine: elk
    pad: 28
    sketch: false
  }
}

title: "1.1 paveikslas. Suaugusiųjų išplėstinio gyvybės palaikymo algoritmas"

pacientas: {
  label: "Pacientas nereaguoja\nir nekvėpuoja normaliai"
  style: {
    fill: "#155a8a"
    stroke: "#155a8a"
    font-size: 26
  }
}

pradzia: {
  label: "Kviesk pagalbą / gaivinimo komandą\nPradėk gaivinimą 30:2\nPrijunk defibriliatorių / monitorių"
  style: {
    fill: "#9ab4d6"
    stroke: "#9ab4d6"
    font-size: 22
  }
}

ritmas: {
  label: "Įvertink ritmą"
  shape: diamond
  style: {
    fill: "#9ab4d6"
    stroke: "#9ab4d6"
    font-size: 22
  }
}

pastaba: {
  label: "Abiem ritmų grupėms:\naukštos kokybės paspaudimai\ndeguonis ir kapnografija\n4 H ir 4 T"
  style: {
    fill: "#eef4fb"
    stroke: "#8aa6c5"
    stroke-dash: 4
    font-size: 18
  }
}

defibriliuotinas: {
  label: "Defibriliuotinas\n(SV / skilvelinė tachikardija be pulso)"
  style: {
    fill: "#f25a43"
    stroke: "#f25a43"
    font-size: 21
  }
}

sokas1: {
  label: "1 šokas"
  style: {
    fill: "#f8d5c6"
    stroke: "#f8d5c6"
    font-size: 22
  }
}

resume_s: {
  label: "Nedelsiant tęsk\ngaivinimą 2 min."
  style: {
    fill: "#f8d5c6"
    stroke: "#f8d5c6"
    font-size: 20
  }
}

po3: {
  label: "Po 3 šoko:\nadrenalinas 1 mg į/v. arba į kaulą\namjodaronas 300 mg"
  style: {
    fill: "#f8d5c6"
    stroke: "#f8d5c6"
    font-size: 18
  }
}

kartok_s: {
  label: "Adrenaliną kartok\nkas 3-5 min."
  style: {
    fill: "#f8d5c6"
    stroke: "#f8d5c6"
    font-size: 18
  }
}

po5: {
  label: "Po 5 šoko:\nsvarstyk amjodaroną 150 mg"
  style: {
    fill: "#f8d5c6"
    stroke: "#f8d5c6"
    font-size: 18
  }
}

nonshock: {
  label: "Nedefibriliuotinas\n(elektrinė veikla be pulso / asistolija)"
  style: {
    fill: "#72aa63"
    stroke: "#72aa63"
    font-size: 21
  }
}

resume_ns: {
  label: "Nedelsiant tęsk\ngaivinimą 2 min."
  style: {
    fill: "#dfe9db"
    stroke: "#dfe9db"
    font-size: 20
  }
}

prieiga: {
  label: "Užtikrink į/v.\narba į kaulą prieigą"
  style: {
    fill: "#dfe9db"
    stroke: "#dfe9db"
    font-size: 18
  }
}

adrenalinas: {
  label: "Skirk adrenalino 1 mg\nkuo greičiau"
  style: {
    fill: "#dfe9db"
    stroke: "#dfe9db"
    font-size: 18
  }
}

kartok_ns: {
  label: "Adrenaliną kartok\nkas 3-5 min."
  style: {
    fill: "#dfe9db"
    stroke: "#dfe9db"
    font-size: 18
  }
}

rosc: {
  label: "Atsistačius spontaninei kraujotakai\n(ROSC)"
  style: {
    fill: "#fff0a8"
    stroke: "#eadb82"
    font-size: 22
  }
}

po_rosc: {
  label: "Po gaivinimo priežiūra:\nABCDE\ndeguonis ir ventiliacija\n12 derivacijų EKG\ngrįžtamos priežasties gydymas"
  style: {
    fill: "#fff7cf"
    stroke: "#eadb82"
    font-size: 18
  }
}

pacientas -> pradzia
pradzia -> ritmas
pradzia -> pastaba
ritmas -> defibriliuotinas: "Defibriliuotinas"
ritmas -> nonshock: "Nedefibriliuotinas"
ritmas -> rosc: "ROSC"

defibriliuotinas -> sokas1
sokas1 -> resume_s
resume_s -> po3
po3 -> kartok_s
kartok_s -> po5

nonshock -> resume_ns
resume_ns -> prieiga
prieiga -> adrenalinas
adrenalinas -> kartok_ns

rosc -> po_rosc

defibriliuotinas.style.stroke: "#f1a28f"
nonshock.style.stroke: "#9dc693"
rosc.style.stroke: "#f0de7f"
